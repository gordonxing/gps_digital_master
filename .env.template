# ============================================================
# 车联网平台 - 私有化部署环境配置模板
# 使用方式: cp .env.template .env && vim .env
# ============================================================

# ======== 基础配置 ========
DOMAIN=http://your-domain.com
SECRET=your-secret-key-at-least-32-chars
TIMEZONE=Asia/Shanghai

# ======== 数据库配置 ========
POSTGRES_USER=iot_admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=iot_platform
POSTGRES_PORT=5432

# lucky_fastapi 数据库连接（使用 lucky schema）
LUCKY_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@iot-postgres:5432/${POSTGRES_DB}?options=-csearch_path%3Dlucky

# geo_fastapi 数据库连接（使用 geo schema）
GEO_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@iot-postgres:5432/${POSTGRES_DB}?options=-csearch_path%3Dgeo

# Traccar 数据库连接（使用 traccar schema）
TRACCAR_DATABASE_URL=jdbc:postgresql://iot-postgres:5432/${POSTGRES_DB}?currentSchema=traccar

# ======== Redis 配置 ========
LUCKY_REDIS_URL=redis://iot-redis:6379/0
GEO_REDIS_URL=redis://iot-redis:6379/1

# ======== 授权配置 ========
LICENSE_ENABLED=true
MACHINE_ID_PATH=/data/.machine_id

# ======== Traccar 设备接入端口配置 ========
# 根据实际使用的设备类型，取消注释需要的端口
# 自定义私有协议
TRACCAR_XCUDP_PORT=5160          # 信春 XCUDP（Q11定位器）
TRACCAR_XCTCP_PORT=5170          # 信春 JT808 TCP
# 常用国标/国际协议
#TRACCAR_GT06_PORT=5023           # GT06/GT06N（谷米等）
#TRACCAR_H02_PORT=5013            # H02（微途/万通等）
#TRACCAR_TK103_PORT=5002          # TK103（拓步达等）
#TRACCAR_GPS103_PORT=5001         # GPS103（科邦Coban GPS103等）
#TRACCAR_HUABAO_PORT=5007         # 华宝/部标 JT808
#TRACCAR_TELTONIKA_PORT=5027      # Teltonika（国际品牌）
#TRACCAR_MEITRACK_PORT=5020       # Meitrack
#TRACCAR_WATCH_PORT=5093          # 儿童手表协议
# Traccar管理端口（仅调试用，生产环境建议关闭）
#TRACCAR_ADMIN_PORT=8082          # Traccar Web管理界面

# ======== 外部地理解析服务（走统一接口）========
GEO_API_URL=http://your-geo-api-domain.com
LUCKY_WEBHOOK_URL=http://lucky-backend:8000/api/v1/webhook/traccar

# ======== 可选：高德/天地图 API ========
#AMAP_API_KEY=your_amap_key
#TIANDITU_API_KEY=your_tianditu_key

